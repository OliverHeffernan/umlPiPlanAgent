  "type": "module",
  "description": "A UML-first planning mode and live localhost plan viewer for pi.",
  "keywords": [
    "pi-package",
    "pi-extension",
    "uml",
    "mermaid",
    "planning"
  ],
  "license": "MIT",
  "author": "Oliver Heffernan",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OliverHeffernan/umlPiPlanAgent.git",
    "directory": ".pi/extensions/visual-plan"
  },
  "homepage": "https://github.com/OliverHeffernan/umlPiPlanAgent#readme",
  "bugs": {
    "url": "https://github.com/OliverHeffernan/umlPiPlanAgent/issues"
  },
  "files": [
